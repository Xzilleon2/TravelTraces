Project TravelTraces {
  database_type: "PostgreSQL"
  Note: "Corrected ERD for TravelTraces based on the current website: authentication/session state, signup category preferences, public and owner-safe profiles, explore places, stories, map pins, Today's Agenda 24-hour map status, Draw Route travel plan drafts, published travel plan stories, calendar items, saved story/place collections, groups, events, social chat, Trace AI conversations, badges, albums, localStorage prototype tables, and account deletion/audit flows."
}

Enum user_role {
  user
  admin
}

Enum account_status {
  active
  suspended
  deleted
}

Enum visibility_scope {
  private
  friends
  group
  public
}

Enum story_status {
  published
  archived
  reported
}

Enum travel_plan_status {
  planning
  ongoing
  completed
  archived
}

Enum travel_plan_destination_status {
  planned
  visited
  completed
}

Enum album_status {
  locked
  draft
  generated
  exported
}

Enum source_entity_type {
  manual
  story
  explore_place
  travel_plan
  travel_plan_destination
  today_agenda
  event
}

Enum deletion_status {
  active
  trashed
  permanently_deleted
}

Enum group_member_role {
  owner
  admin
  organizer
  traveler
  member
}

Enum event_status {
  draft
  published
  cancelled
  completed
}

Enum conversation_type {
  direct
  group
  event
}

Enum message_type {
  text
  image
  pin
  system
}

Enum ai_chat_role {
  user
  assistant
  system
}

Enum ai_chat_message_status {
  pending
  sent
  failed
}

Table users {
  user_id varchar [pk]
  email varchar [not null, unique]
  password_hash varchar [not null]
  full_name varchar [not null]
  username varchar [unique]
  avatar_url varchar
  avatar_position_x decimal(5,2) [not null, default: 50, note: "Free-form image crop position saved by the avatar/photo drag editor."]
  avatar_position_y decimal(5,2) [not null, default: 50, note: "Free-form image crop position saved by the avatar/photo drag editor."]
  cover_url varchar
  tagline varchar
  location varchar
  nationality varchar
  bio text
  interests_json json [note: "Category selection after signup, e.g. Beaches, Mountains, Food, Adventure, Culture, Wildlife, Festivals. Used to personalize Explore/Stories/Travel Plan feeds."]
  travel_style varchar
  profile_completion_percent int [not null, default: 0]
  profile_completion_dismissed_at timestamp [note: "Per-user dismissal for the profile completion reminder while the profile is incomplete."]
  role user_role [not null, default: "user"]
  status account_status [not null, default: "active"]
  profile_visibility visibility_scope [not null, default: "public"]
  email_public boolean [not null, default: false, note: "Public/visitor profiles must mask or omit email unless the owner explicitly exposes it."]
  email_verified boolean [not null, default: false]
  government_id varchar
  current_plan_name varchar [not null, default: "Free", note: "Profile/settings display value. Billing history remains in subscriptions."]
  xp_points int [not null, default: 0]
  current_level int [not null, default: 1]
  followers_count int [not null, default: 0]
  following_count int [not null, default: 0]
  stories_count int [not null, default: 0]
  travel_plans_count int [not null, default: 0]
  travel_groups_count int [not null, default: 0]
  pins_count int [not null, default: 0]
  saved_places_count int [not null, default: 0]
  calendar_timezone varchar [not null, default: "Asia/Manila"]
  joined_at timestamp [not null]
  last_login_at timestamp
  created_at timestamp [not null]
  updated_at timestamp [not null]
  deleted_at timestamp
}

Table auth_sessions {
  session_id varchar [pk]
  user_id varchar [not null]
  email_snapshot varchar [note: "Local prototype auth rows store email alongside user_id for duplicate-email and login checks."]
  session_token_hash varchar [not null, unique]
  token_expires_at timestamp [not null]
  revoked_at timestamp
  last_seen_at timestamp
  user_agent varchar
  ip_address varchar
  created_at timestamp [not null]
}

Table account_deletion_requests {
  deletion_request_id varchar [pk]
  user_id varchar [not null]
  requested_at timestamp [not null]
  final_confirmation varchar [not null]
  status varchar [not null, default: "pending"]
  deleted_counts_json json [note: "Counts returned to the frontend after stories, pins, plans, saves, groups, sessions, and related records are removed or anonymized."]
  residual_access_removed boolean [not null, default: false]
  completed_at timestamp
}

Table user_reports {
  report_id varchar [pk]
  reported_user_id varchar [not null]
  reporter_id varchar [not null]
  reason varchar [not null]
  details text
  status varchar [not null, default: "open"]
  created_at timestamp [not null]
  reviewed_at timestamp
  reviewed_by varchar
}

Table user_follows {
  follower_id varchar [not null]
  following_id varchar [not null]
  followed_at timestamp [not null]

  indexes {
    (follower_id, following_id) [pk]
  }
}

Table subscriptions {
  subscription_id varchar [pk]
  user_id varchar [not null]
  plan_name varchar [not null, default: "Free"]
  status varchar [not null]
  start_date date [not null]
  end_date date
  created_at timestamp [not null]
  updated_at timestamp [not null]
}

Table notification_preferences {
  user_id varchar [pk]
  meetup_arrivals boolean [not null, default: true]
  destination_arrivals boolean [not null, default: true]
  check_ins boolean [not null, default: true]
  checkpoints boolean [not null, default: true]
  group_ride_start boolean [not null, default: true]
  event_arrivals boolean [not null, default: true]
}

Table badges {
  badge_id varchar [pk]
  name varchar [not null]
  description text [not null]
  icon varchar
  xp_reward int [not null, default: 0]
  rarity varchar [not null]
  unlock_rule_json json
  sort_order int [not null, default: 0]
}

Table user_badges {
  user_id varchar [not null]
  badge_id varchar [not null]
  achieved_at timestamp [not null]

  indexes {
    (user_id, badge_id) [pk]
  }
}

Table community_challenges {
  challenge_id varchar [pk]
  title varchar [not null]
  description text [not null]
  category varchar
  xp_reward int [not null, default: 0]
  badge_id varchar
  starts_at timestamp
  ends_at timestamp
  active boolean [not null, default: true]
  created_at timestamp [not null]
  updated_at timestamp [not null]
}

Table user_challenge_progress {
  challenge_id varchar [not null]
  user_id varchar [not null]
  progress_count int [not null, default: 0]
  target_count int [not null, default: 1]
  completed boolean [not null, default: false]
  completed_at timestamp
  updated_at timestamp [not null]

  indexes {
    (challenge_id, user_id) [pk]
  }
}

Table explore_places {
  place_id varchar [pk]
  created_by_admin_id varchar
  title varchar [not null]
  slug varchar [not null, unique]
  about text [not null]
  province varchar
  region varchar
  country varchar [not null, default: "Philippines"]
  category varchar [not null]
  terrain varchar
  best_months varchar
  difficulty varchar
  rating decimal(3,2) [not null, default: 0]
  reviews_count int [not null, default: 0]
  explorers_count int [not null, default: 0]
  pins_count int [not null, default: 0]
  latitude decimal(10,7)
  longitude decimal(10,7)
  hero_image_url varchar
  created_by_admin boolean [not null, default: true]
  is_featured boolean [not null, default: false]
  created_at timestamp [not null]
  updated_at timestamp [not null]
}

Table explore_place_photos {
  photo_id varchar [pk]
  place_id varchar [not null]
  image_url varchar [not null]
  caption varchar
  sort_order int [not null, default: 0]
  created_at timestamp [not null]
}

Table explore_place_highlights {
  highlight_id varchar [pk]
  place_id varchar [not null]
  title varchar [not null]
  sort_order int [not null, default: 0]
}

Table explore_place_tags {
  place_id varchar [not null]
  tag varchar [not null]

  indexes {
    (place_id, tag) [pk]
  }
}

Table explore_place_contributors {
  place_id varchar [not null]
  user_id varchar [not null]
  contributed_at timestamp [not null]

  indexes {
    (place_id, user_id) [pk]
  }
}

Table stories {
  story_id varchar [pk]
  author_id varchar [not null]
  place_id varchar
  pin_id varchar
  title varchar [not null]
  subtitle varchar
  excerpt text
  body text [not null]
  category varchar [not null]
  location_name varchar
  region varchar
  latitude decimal(10,7)
  longitude decimal(10,7)
  cover_image_url varchar
  cover_position_x decimal(5,2) [not null, default: 50]
  cover_position_y decimal(5,2) [not null, default: 50]
  read_time varchar
  visibility visibility_scope [not null, default: "public"]
  status story_status [not null, default: "published", note: "Story posts are never drafts. Users can switch visibility between private, friends, group, and public, and can edit/delete their own published story post."]
  deletion_status deletion_status [not null, default: "active"]
  likes_count int [not null, default: 0]
  saves_count int [not null, default: 0]
  comments_count int [not null, default: 0]
  posted_at timestamp [not null]
  created_at timestamp [not null]
  updated_at timestamp [not null]
  deleted_at timestamp
}

Table story_photos {
  photo_id varchar [pk]
  story_id varchar [not null]
  image_url varchar [not null]
  caption varchar
  object_position varchar
  photo_position_x decimal(5,2) [not null, default: 50]
  photo_position_y decimal(5,2) [not null, default: 50]
  sort_order int [not null, default: 0]
  created_at timestamp [not null]
}

Table story_comments {
  comment_id varchar [pk]
  story_id varchar [not null]
  user_id varchar [not null]
  author_snapshot varchar [note: "Local storyEngagements stores author text directly for responsive cross-tab comment display."]
  avatar_snapshot varchar
  parent_comment_id varchar
  content text [not null]
  likes_count int [not null, default: 0]
  created_at timestamp [not null]
  updated_at timestamp [not null]
  deleted_at timestamp
}

Table story_likes {
  reaction_id varchar [pk]
  story_id varchar [not null]
  user_id varchar [not null]
  reaction_type varchar [not null, default: "like"]
  created_at timestamp [not null]

  indexes {
    (story_id, user_id, reaction_type) [unique]
  }
}

Table saved_stories {
  story_id varchar [not null]
  user_id varchar [not null]
  collection_id varchar
  saved_at timestamp [not null]
  deleted_at timestamp

  indexes {
    (story_id, user_id) [pk]
  }
}

Table story_collections {
  collection_id varchar [pk]
  owner_id varchar [not null]
  name varchar [not null]
  description text
  created_at timestamp [not null]
  updated_at timestamp [not null]
}

Table story_collection_items {
  collection_id varchar [not null]
  story_id varchar [not null]
  added_at timestamp [not null]

  indexes {
    (collection_id, story_id) [pk]
  }
}

Table user_maps {
  map_id varchar [pk]
  owner_id varchar [not null]
  creator_id varchar [not null]
  title varchar [not null]
  description text
  scope visibility_scope [not null, default: "private"]
  is_default boolean [not null, default: false]
  created_at timestamp [not null]
  updated_at timestamp [not null]
}

Table user_map_groups {
  map_id varchar [not null]
  group_id varchar [not null]

  indexes {
    (map_id, group_id) [pk]
  }
}

Table pins {
  pin_id varchar [pk]
  post_id varchar [not null]
  map_id varchar
  creator_id varchar [not null]
  story_id varchar
  place_id varchar
  travel_plan_id varchar
  travel_plan_destination_id varchar
  source_entity_type source_entity_type [not null, default: "manual"]
  source_entity_id varchar
  title varchar [not null]
  subtitle varchar
  note text
  description text
  address varchar
  latitude decimal(10,7) [not null]
  longitude decimal(10,7) [not null]
  map_x_percent decimal(5,2)
  map_y_percent decimal(5,2)
  category varchar
  scope visibility_scope [not null, default: "private"]
  source varchar [not null, default: "manual"]
  media_json json [note: "Frontend localStorage prototype stores story links as media.storyId. Legacy media.storyDraftId is only recognized for cleanup/backward compatibility; Stories do not have drafts."]
  collaborator_ids_json json [note: "Local prototype field for Collab Map pins. Production uses pin_collaborators; only mutual followers/friends are eligible."]
  deletion_status deletion_status [not null, default: "active"]
  created_at timestamp [not null]
  updated_at timestamp [not null]
  deleted_at timestamp
}

Table pin_photos {
  photo_id varchar [pk]
  pin_id varchar [not null]
  image_url varchar [not null]
  sort_order int [not null, default: 0]
  created_at timestamp [not null]
}

Table pin_groups {
  pin_id varchar [not null]
  group_id varchar [not null]

  indexes {
    (pin_id, group_id) [pk]
  }
}

Table pin_collaborators {
  pin_id varchar [not null]
  collaborator_id varchar [not null]
  added_by varchar [not null]
  can_edit boolean [not null, default: false]
  added_at timestamp [not null]

  indexes {
    (pin_id, collaborator_id) [pk]
  }

  Note: "Collab Map collaborators are restricted to friends: User A follows User B and User B follows User A."
}

Table routes {
  record_id varchar [pk]
  route_id varchar [not null]
  session_id varchar
  creator_id varchar [not null]
  travel_plan_id varchar
  scope visibility_scope [not null, default: "private"]
  engine varchar [not null, default: "osrm"]
  input_mode varchar [note: "Draw Route supports click-points and drag-line input. Points connect sequentially: 1 to 2, 2 to 3, and so on."]
  requested_point_count int
  snapped_to_route boolean [not null, default: false]
  route_json json [not null]
  distance_m decimal(12,2)
  duration_s int
  is_drawn_route boolean [not null, default: false]
  created_at timestamp [not null]
  updated_at timestamp [not null]
}

Table route_points {
  point_id varchar [pk]
  record_id varchar [not null]
  point_order int [not null]
  latitude decimal(10,7) [not null]
  longitude decimal(10,7) [not null]
  label varchar
  snapped_latitude decimal(10,7)
  snapped_longitude decimal(10,7)
  place_name varchar
  category varchar
}

Table route_groups {
  record_id varchar [not null]
  group_id varchar [not null]

  indexes {
    (record_id, group_id) [pk]
  }
}

Table travel_plan_stories {
  travel_plan_id varchar [pk]
  owner_id varchar [not null]
  route_record_id varchar
  name varchar [not null]
  subtitle varchar
  owner_name_snapshot varchar [note: "Stored for card/article display while still keeping owner_id as the relationship source of truth."]
  cover_image_url varchar [note: "Drafts may start without a cover. A completed Travel Plan cannot be published until the owner chooses or uploads this cover image."]
  cover_position varchar
  cover_position_x decimal(5,2) [not null, default: 50]
  cover_position_y decimal(5,2) [not null, default: 50]
  description text
  route_geometry_json json
  visibility visibility_scope [not null, default: "private", note: "Travel plans stay private while planning or ongoing. Public visibility is allowed only after completion."]
  status travel_plan_status [not null, default: "planning"]
  published boolean [not null, default: false, note: "Owner drafts are hidden from the public Travel Plans feed until the route is completed and the owner publishes it."]
  publishable boolean [not null, default: false, note: "True only when every destination has been completed and the owner has chosen a cover image."]
  public_feed_visible boolean [not null, default: false, note: "Derived from published = true and status = completed. This controls whether the card appears beside public Explore, Stories, Community, and Events content."]
  owner_draft_visible boolean [not null, default: true, note: "Shows the owner's private unfinished or unpublished Travel Plan cards in Profile > Draft Plans. Draft behavior belongs to Travel Plans only, not regular Stories."]
  total_destinations int [not null, default: 0]
  completed_destinations int [not null, default: 0]
  total_travel_days int [not null, default: 1]
  likes_count int [not null, default: 0, note: "Engagement is shown only after the plan is published publicly."]
  saves_count int [not null, default: 0, note: "Saves are available only for published completed plans."]
  comments_count int [not null, default: 0, note: "Comments are enabled only for published completed plans."]
  comments_enabled boolean [not null, default: false, note: "Turns true only after documentation is complete and the owner publishes the plan."]
  album_template varchar
  album_unlocked boolean [not null, default: false]
  owner_can_print_album boolean [not null, default: false, note: "Print Album is an owner-only action. Public viewers can view completed routes but cannot print another user's album from the detail page."]
  deletion_status deletion_status [not null, default: "active"]
  published_at timestamp
  created_at timestamp [not null]
  updated_at timestamp [not null]
  archived_at timestamp
  deleted_at timestamp
}

Table travel_plan_groups {
  travel_plan_id varchar [not null]
  group_id varchar [not null]

  indexes {
    (travel_plan_id, group_id) [pk]
  }
}

Table travel_plan_destinations {
  destination_id varchar [pk]
  travel_plan_id varchar [not null]
  place_id varchar
  route_point_id varchar
  pin_id varchar
  destination_order int [not null]
  place_name varchar [not null]
  title varchar [note: "Editable point title shown in the Substack-style travel plan article."]
  latitude decimal(10,7) [not null]
  longitude decimal(10,7) [not null]
  category varchar [not null, default: "Hidden Gems"]
  planned_day int [not null, default: 1]
  planned_date date [not null]
  planned_time time
  planned_description text [note: "Maps to the frontend destination.description field. This is the inline article copy shown as TYPE HERE before the visit can be documented."]
  notes text [note: "Inline route note for this point, edited directly in the article-style draft."]
  photos_json json [note: "Temporary local draft photos for destination article display before/while documentation is being edited."]
  status travel_plan_destination_status [not null, default: "planned"]
  documentable_after timestamp [not null, note: "Destination can be documented only after this scheduled date/time has arrived."]
  reordered_at timestamp [note: "Updated when the owner drags this destination to a new ordered position."]
  visited_at timestamp
  completed_at timestamp
  created_at timestamp [not null]
  updated_at timestamp [not null]
  deleted_at timestamp

  indexes {
    (travel_plan_id, destination_order) [unique]
    (travel_plan_id, planned_date, planned_time) [unique, note: "Prevents two destinations in the same plan from sharing the same planned date and time."]
  }
}

Table travel_plan_destination_documents {
  document_id varchar [pk]
  destination_id varchar [not null, unique]
  pin_id varchar
  story_id varchar
  scope visibility_scope [not null, default: "private"]
  place_name varchar [not null]
  category varchar [not null]
  title varchar [not null]
  subtitle varchar
  description text [not null]
  date_visited date [not null]
  publish_to_map boolean [not null, default: false]
  publish_as_story boolean [not null, default: false]
  documented_after_schedule boolean [not null, default: true]
  documented_at timestamp [not null]
  created_at timestamp [not null]
  updated_at timestamp [not null]
  deleted_at timestamp
}

Table travel_plan_destination_photos {
  photo_id varchar [pk]
  document_id varchar [not null]
  image_url varchar [not null]
  caption varchar
  object_position varchar
  photo_position_x decimal(5,2) [not null, default: 50]
  photo_position_y decimal(5,2) [not null, default: 50]
  sort_order int [not null, default: 0]
  created_at timestamp [not null]
}

Table today_agendas {
  agenda_id varchar [pk]
  owner_id varchar [not null]
  owner_name_snapshot varchar [not null]
  owner_avatar_snapshot varchar
  title varchar [not null]
  activity varchar [not null]
  place_name varchar [not null]
  latitude decimal(10,7) [not null]
  longitude decimal(10,7) [not null]
  scope visibility_scope [not null, default: "public"]
  group_ids_json json [not null, note: "Local TodayAgenda stores groupIds as a string array when scope is group."]
  created_at timestamp [not null]
  expires_at timestamp [not null, note: "Automatically expires and disappears after 24 hours."]
  deleted_at timestamp

  indexes {
    (owner_id, expires_at)
    (scope, expires_at)
  }
}

Table travel_plan_albums {
  album_id varchar [pk]
  travel_plan_id varchar [not null, unique]
  owner_id varchar [not null]
  template_name varchar [not null]
  cover_title varchar
  cover_image_url varchar
  status album_status [not null, default: "locked"]
  album_json json
  printable_export_url varchar
  generated_at timestamp
  created_at timestamp [not null]
  updated_at timestamp [not null]
  deleted_at timestamp
}

Table travel_plan_album_pages {
  page_id varchar [pk]
  album_id varchar [not null]
  destination_id varchar
  page_order int [not null]
  title varchar
  body text
  layout varchar
  image_url varchar
  page_json json
  created_at timestamp [not null]
  updated_at timestamp [not null]

  indexes {
    (album_id, page_order) [unique]
  }
}

Table travel_plan_comments {
  comment_id varchar [pk]
  travel_plan_id varchar [not null]
  user_id varchar [not null]
  parent_comment_id varchar
  content text [not null]
  likes_count int [not null, default: 0]
  created_at timestamp [not null]
  updated_at timestamp [not null]
  deleted_at timestamp
}

Table travel_plan_likes {
  travel_plan_id varchar [not null]
  user_id varchar [not null]
  created_at timestamp [not null]

  indexes {
    (travel_plan_id, user_id) [pk]
  }
}

Table saved_travel_plans {
  travel_plan_id varchar [not null]
  user_id varchar [not null]
  collection_id varchar
  saved_at timestamp [not null]
  deletion_status deletion_status [not null, default: "active"]
  deleted_at timestamp

  indexes {
    (travel_plan_id, user_id) [pk]
  }
}

Table user_calendar_items {
  calendar_item_id varchar [pk]
  user_id varchar [not null]
  travel_plan_id varchar
  destination_id varchar
  title varchar [not null]
  place_name varchar
  starts_at timestamp [not null]
  ends_at timestamp
  latitude decimal(10,7)
  longitude decimal(10,7)
  source_entity_type source_entity_type [not null, default: "travel_plan_destination"]
  source_entity_id varchar
  created_at timestamp [not null]
  updated_at timestamp [not null]
  deleted_at timestamp
}

Table tracking_sessions {
  session_id varchar [pk]
  user_id varchar [not null]
  route_id varchar
  scope visibility_scope [not null, default: "private"]
  status varchar [not null, default: "active"]
  last_location_json json
  created_at timestamp [not null]
  updated_at timestamp [not null]
}

Table meetup_requests {
  request_id varchar [pk]
  creator_id varchar [not null]
  map_id varchar
  scope visibility_scope [not null, default: "private"]
  fair_region_json json
  midpoint_json json
  suggestions_json json
  fallback_strategy_json json
  scoring_weights_json json
  created_at timestamp [not null]
  updated_at timestamp [not null]
}

Table meetup_participants {
  request_id varchar [not null]
  user_id varchar [not null]
  start_latitude decimal(10,7)
  start_longitude decimal(10,7)
  travel_limit_minutes int

  indexes {
    (request_id, user_id) [pk]
  }
}

Table travel_groups {
  circle_id varchar [pk]
  group_id varchar [not null, unique]
  name varchar [not null]
  owner_id varchar [not null]
  created_at timestamp [not null]
  updated_at timestamp [not null]
}

Table travel_group_members {
  circle_id varchar [not null]
  user_id varchar [not null]
  display_name varchar [not null]
  role group_member_role [not null, default: "member"]
  phone varchar
  avatar varchar
  admin boolean [not null, default: false]
  location_sharing_enabled boolean [not null, default: true]
  joined_at timestamp [not null]

  indexes {
    (circle_id, user_id) [pk]
  }
}

Table circle_invites {
  invite_id varchar [pk]
  circle_id varchar [not null]
  code varchar [not null, unique]
  created_by varchar [not null]
  created_at timestamp [not null]
  expires_at timestamp [not null]
  uses int [not null, default: 0]
  expired boolean [not null, default: false]
}

Table saved_places {
  place_id varchar [pk]
  circle_id varchar [not null]
  creator_id varchar [not null]
  name varchar [not null]
  label varchar [not null]
  latitude decimal(10,7) [not null]
  longitude decimal(10,7) [not null]
  radius_m int [not null, default: 180]
  created_at timestamp [not null]
  updated_at timestamp [not null]
}

Table tracked_devices {
  device_id varchar [pk]
  circle_id varchar [not null]
  owner_id varchar [not null]
  name varchar [not null]
  kind varchar [not null]
  status varchar [not null]
  battery_percent int
  last_seen timestamp
  last_coordinate_json json
  created_at timestamp [not null]
  updated_at timestamp [not null]
}

Table member_locations {
  circle_id varchar [not null]
  user_id varchar [not null]
  coordinate_json json
  accuracy_m decimal
  activity varchar [not null]
  sharing_enabled boolean [not null]
  visibility_scope varchar [not null]
  event_id varchar
  travel_group_id varchar
  status_text varchar [not null]
  inside_place_ids_json json
  updated_at timestamp [not null]

  indexes {
    (circle_id, user_id) [pk]
  }
}

Table circle_events {
  event_id varchar [pk]
  circle_id varchar [not null]
  user_id varchar [not null]
  type varchar [not null]
  place_id varchar
  message text [not null]
  read_by_json json
  created_at timestamp [not null]
}

Table events {
  event_id varchar [pk]
  organizer_id varchar [not null]
  organizer_name_snapshot varchar
  location_id int [note: "Local hosted tour form uses a numeric destination/location id."]
  place_id varchar
  destination_title varchar
  province varchar
  title varchar [not null]
  event_type varchar [not null]
  description text [not null]
  long_description text
  event_date date [not null]
  event_time time
  location_name varchar [not null]
  meeting_point varchar
  is_paid boolean [not null, default: false]
  price decimal(10,2) [not null, default: 0]
  max_participants int [not null]
  status event_status [not null, default: "published"]
  hero_image_url varchar
  image_url varchar [note: "Local eventsApi payload stores imageUrl; hero_image_url is the production display equivalent."]
  tour_guide_license varchar
  hosted_tour_source varchar [not null, default: "event_page"]
  created_at timestamp [not null]
  updated_at timestamp [not null]
}

Table event_participants {
  event_id varchar [not null]
  user_id varchar [not null]
  status varchar [not null, default: "joined"]
  joined_at timestamp [not null]

  indexes {
    (event_id, user_id) [pk]
  }
}

Table event_photos {
  photo_id varchar [pk]
  event_id varchar [not null]
  image_url varchar [not null]
  caption varchar
  sort_order int [not null, default: 0]
}

Table event_schedule_items {
  schedule_item_id varchar [pk]
  event_id varchar [not null]
  item_order int [not null]
  content text [not null]
}

Table event_tags {
  event_id varchar [not null]
  tag varchar [not null]

  indexes {
    (event_id, tag) [pk]
  }
}

Table conversations {
  conversation_id varchar [pk]
  owner_id varchar [note: "Local chat panel stores conversations per owner for prototype isolation."]
  type conversation_type [not null]
  name varchar
  avatar_url varchar
  avatar_background varchar
  initials varchar
  last_message text
  time_label varchar
  online boolean [not null, default: false]
  unread boolean [not null, default: false]
  muted boolean [not null, default: false]
  gamified_key varchar
  event_id varchar
  group_id varchar
  created_by varchar
  created_at timestamp [not null]
  updated_at timestamp [not null]
}

Table conversation_users {
  conversation_id varchar [not null]
  user_id varchar [not null]
  role varchar [not null, default: "member"]
  muted boolean [not null, default: false]
  unread_count int [not null, default: 0]
  joined_at timestamp [not null]

  indexes {
    (conversation_id, user_id) [pk]
  }
}

Table messages {
  message_id varchar [pk]
  conversation_id varchar [not null]
  owner_id varchar [note: "Local chat panel stores messages per owner for prototype isolation."]
  sender_id varchar
  sender_direction varchar [note: "Local UI value: me or them."]
  sender_name_snapshot varchar
  message_type message_type [not null, default: "text"]
  body text [not null]
  attachment_url varchar
  pin_id varchar
  time_label varchar
  read boolean [not null, default: false]
  read_at timestamp
  created_at timestamp [not null]
  deleted_at timestamp
}

Table ai_chat_conversations {
  conversation_id varchar [pk]
  owner_id varchar [not null]
  route varchar [not null, default: "/chat", note: "Frontend workspace route represented in the JSON chat contract."]
  title varchar [note: "Generated from the opening prompt or explicitly renamed by the owner."]
  model_name varchar [note: "Model identifier returned by the configured Trace AI provider; secrets and provider URLs remain environment configuration."]
  saved boolean [not null, default: false]
  pinned boolean [not null, default: false]
  last_message_at timestamp
  created_at timestamp [not null]
  updated_at timestamp [not null]
  deleted_at timestamp

  indexes {
    (owner_id, updated_at)
    (owner_id, saved)
    (owner_id, pinned)
  }

  Note: "Trace AI workspace conversation. The browser currently prototypes this through traveltraces.aiChat.v1; POST /api/chat creates or continues the backend conversation while the page remains GET /chat."
}

Table ai_chat_messages {
  message_id varchar [pk]
  conversation_id varchar [not null]
  role ai_chat_role [not null]
  content text [not null]
  status ai_chat_message_status [not null, default: "sent"]
  bookmarked boolean [not null, default: false]
  model_name varchar [note: "Populated for assistant messages when the AI provider returns a model identifier."]
  error_status_code int [note: "Optional gateway status for failed model requests, such as 502, 503, or 504."]
  created_at timestamp [not null]
  deleted_at timestamp

  indexes {
    (conversation_id, created_at)
    (conversation_id, bookmarked)
  }

  Note: "Stores the ordered user, assistant, and system history sent by the typed /api/chat JSON contract. Failed responses remain retryable without fabricating assistant content."
}

Table user_local_buckets {
  bucket_id varchar [pk]
  user_id varchar [not null]
  bucket_name varchar [not null]
  value_json json [not null]
  created_at timestamp [not null]
  updated_at timestamp [not null]

  indexes {
    (user_id, bucket_name) [unique]
  }

  Note: "Represents namespaced localStorage buckets like traveltraces:user:{userId}:savedStories, savedTravelPlans, savedMarkers, profile, achievements, draft plans, travel groups, calendar, settings, chatbox state, and the temporary traveltraces.aiChat.v1 Trace AI payload."
}

Table place_search_cache {
  search_cache_id varchar [pk]
  query varchar [not null]
  normalized_query varchar [not null]
  provider varchar [not null]
  result_json json [not null]
  latitude_hint decimal(10,7)
  longitude_hint decimal(10,7)
  created_at timestamp [not null]
  expires_at timestamp

  indexes {
    (normalized_query, provider)
  }

  Note: "Supports smart place search autocomplete across local app data, saved places, tourist spots, pins, MapTiler, Photon/Pelias, and fallback Nominatim."
}

Table travel_collections {
  collection_id varchar [pk]
  owner_id varchar [not null]
  name varchar [not null]
  description text
  collection_type varchar [not null, default: "saved_stories", note: "Supports saved story playlists and saved destinations/travel plans from the profile/saved library."]
  created_at timestamp [not null]
  updated_at timestamp [not null]
  deleted_at timestamp
}

Table saved_tourist_spots {
  saved_spot_id varchar [pk]
  source_entity_type source_entity_type [not null, default: "story", note: "Saved Places library can save stories, travel plans, individual pins, or explore places."]
  source_entity_id varchar
  place_id varchar
  story_id varchar
  travel_plan_id varchar
  pin_id varchar
  owner_id varchar [not null]
  collection_id varchar
  name varchar [not null]
  subtitle varchar
  category varchar [not null]
  cover_image_url varchar
  latitude decimal(10,7) [not null]
  longitude decimal(10,7) [not null]
  notes text
  deletion_status deletion_status [not null, default: "active"]
  saved_at timestamp [not null]
  deleted_at timestamp
}

Table audit_log {
  audit_id int [pk, increment]
  actor_id varchar
  action varchar [not null]
  entity_type varchar [not null]
  entity_id varchar
  details_json json
  created_at timestamp [not null]
}

Table local_storage_tables {
  local_table_key varchar [pk]
  dbml_table_name varchar [not null]
  purpose text [not null]
  browser_storage_key varchar [not null, unique]
  mirrors_backend_table boolean [not null, default: true]
  created_at timestamp
  updated_at timestamp
  Note: "Prototype-only map of DBML tables to localStorage keys. This lets the frontend test all flows locally before PostgreSQL is connected."
}

