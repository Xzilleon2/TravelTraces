# VITE_API_BASE_URL: Optional. Leave empty to use Vite's local /api proxy.
VITE_API_BASE_URL=""

# VITE_API_PROXY_TARGET: Used only by the Vite dev server.
VITE_API_PROXY_TARGET="http://localhost:8000"

# MapTiler API key for MapLibre basemap styles.
VITE_MAPTILER_KEY=""

# Cesium Ion token for the Maps Workspace 3D Globe layer.
VITE_CESIUM_ION_TOKEN="your-cesium-ion-token"
