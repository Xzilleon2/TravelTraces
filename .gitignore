# TravelTraces repository ignores

# Dependencies
node_modules/
frontend/node_modules/

# Frontend build output and caches
dist/
frontend/dist/
build/
frontend/build/
.vite/
frontend/node_modules/.vite/
coverage/
frontend/coverage/

# Backend virtual environments and Python caches
.venv/
venv/
backend/.venv/
backend/venv/
__pycache__/
*/__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Environment and secrets
.env
.env.*
frontend/.env
frontend/.env.*
backend/.env
backend/.env.*
!.env.example
!frontend/.env.example
!backend/.env.example

# Logs
*.log
*.out.log
*.err.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Local data and generated runtime files
backend/data/*.json
backend/data/*.tmp
backend/data/*.db
backend/data/*.sqlite
backend/data/*.sqlite3
*.db
*.sqlite
*.sqlite3

# OS and editor noise
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
