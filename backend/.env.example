APP_ENV=production
API_CORS_ORIGINS=https://travelplaces.example.com
REQUIRE_AUTH=true
AUTH_COOKIE_SECURE=true
AUTH_SECRET=replace-with-64-random-bytes
WS_SESSION_SECRET=replace-with-different-64-random-bytes
BOOTSTRAP_USER_EMAIL=admin@example.com
BOOTSTRAP_USER_ID=admin
BOOTSTRAP_USER_PASSWORD_HASH=$argon2id$v=19$m=65536,t=3,p=4$replace-with-argon2-hash
BOOTSTRAP_USER_GROUP_IDS=ops,travelers
REDIS_URL=redis://redis:6379/0
MAX_REQUEST_BYTES=1048576
GROQ_API_KEY=gsk_your_api_key_here
GROQ_MODEL=openai/gpt-oss-20b
GROQ_BASE_URL=https://api.groq.com/openai/v1
